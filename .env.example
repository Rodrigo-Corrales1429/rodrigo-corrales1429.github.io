# ============================================================================
# Variables de entorno del backend del Asesor Valquiria
# ============================================================================
# Copia este archivo a `.env` y rellena los valores. NUNCA subas el .env real
# a GitHub — agrégalo a tu .gitignore. En Render, configúralas en el panel
# "Environment" del servicio.
# ============================================================================

# --- Obligatoria ---
GEMINI_API_KEY=tu_api_key_real_aqui

# --- Opcionales (con valores default seguros si las omites) ---

# Puerto donde escucha el servidor. Render asigna el suyo automáticamente.
PORT=3000

# Modelo de Gemini. gemini-2.5-flash es el balance ideal coste/calidad.
# Para casos más exigentes podrías usar gemini-2.5-pro.
GEMINI_MODEL=gemini-2.5-flash

# Reglas de envío en CENTAVOS (enteros).
# Ejemplo: 99900 = $999.00 MXN
ENVIO_GRATIS_DESDE_CENTAVOS=99900
COSTO_ENVIO_CENTAVOS=15000

# Tope anti-abuso de cantidad por línea de cotización.
CANTIDAD_MAXIMA_POR_LINEA=200
